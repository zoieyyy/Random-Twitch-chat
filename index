<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Twitch Chat → Green Screen</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --key:#00ff00;
    --font-size:18px;
    --gap:6px;
    --panel:#18181b;
    --panel-2:#1f1f23;
    --line:#2a2a2e;
    --txt:#efeff1;
    --muted:#adadb8;
    --acc:#9147ff;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    font-family:'Inter',system-ui,sans-serif;
    display:flex;
    background:#0e0e10;
    color:var(--txt);
    overflow:hidden;
  }

  /* ---------- Controls ---------- */
  .controls{
    width:330px;
    flex:0 0 330px;
    background:var(--panel);
    border-right:1px solid var(--line);
    padding:18px;
    overflow-y:auto;
    display:flex;
    flex-direction:column;
    gap:16px;
  }
  .controls h1{
    font-size:15px;font-weight:700;letter-spacing:.3px;
    display:flex;align-items:center;gap:8px;
  }
  .controls h1 .dot{width:9px;height:9px;border-radius:50%;background:var(--acc)}
  .grp{display:flex;flex-direction:column;gap:6px}
  .grp > label{font-size:11px;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:600}
  textarea{
    width:100%;height:200px;resize:vertical;
    background:var(--panel-2);border:1px solid var(--line);border-radius:8px;
    color:var(--txt);font-family:ui-monospace,'SF Mono',Menlo,monospace;
    font-size:12px;line-height:1.5;padding:10px;
  }
  textarea:focus{outline:none;border-color:var(--acc)}
  .row{display:flex;gap:8px}
  button{
    flex:1;cursor:pointer;border:none;border-radius:8px;padding:10px;
    font-family:inherit;font-size:13px;font-weight:600;color:var(--txt);
    background:var(--panel-2);border:1px solid var(--line);transition:.12s;
  }
  button:hover{background:#2a2a30}
  button.primary{background:var(--acc);border-color:var(--acc)}
  button.primary:hover{background:#7d31e8}
  .opt{display:flex;align-items:center;justify-content:space-between;gap:10px;font-size:13px}
  .opt input[type=range]{flex:1;accent-color:var(--acc)}
  .opt .val{font-variant-numeric:tabular-nums;color:var(--muted);min-width:46px;text-align:right;font-size:12px}
  .seg{display:flex;border:1px solid var(--line);border-radius:8px;overflow:hidden}
  .seg button{border:none;border-radius:0;border-right:1px solid var(--line)}
  .seg button:last-child{border-right:none}
  .seg button.on{background:var(--acc)}
  .switch{display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;user-select:none}
  .switch input{appearance:none;width:36px;height:20px;background:var(--line);border-radius:20px;position:relative;cursor:pointer;transition:.15s;flex:0 0 36px}
  .switch input:checked{background:var(--acc)}
  .switch input::after{content:"";position:absolute;top:2px;left:2px;width:16px;height:16px;border-radius:50%;background:#fff;transition:.15s}
  .switch input:checked::after{left:18px}
  .swatches{display:flex;gap:8px}
  .swatches .sw{width:30px;height:30px;border-radius:6px;cursor:pointer;border:2px solid transparent}
  .swatches .sw.on{border-color:#fff}
  .hint{font-size:11px;color:var(--muted);line-height:1.5}
  .err{font-size:12px;color:#ff6b6b;min-height:14px}

  /* emotes */
  .thumbs{display:flex;flex-wrap:wrap;gap:6px;max-height:150px;overflow-y:auto;padding:6px;background:var(--panel-2);border:1px solid var(--line);border-radius:8px;min-height:44px}
  .thumbs:empty::after{content:"No emotes loaded — paste links above and hit Load";color:var(--muted);font-size:11px;align-self:center}
  .thumb{width:36px;height:36px;border-radius:6px;display:flex;align-items:center;justify-content:center;background:#0e0e10;border:2px solid transparent;cursor:pointer;opacity:.32;transition:.12s;overflow:hidden}
  .thumb.on{opacity:1;border-color:var(--acc)}
  .thumb img{max-width:100%;max-height:100%;display:block}
  .emote{height:1.5em;width:auto;vertical-align:middle;margin:-2px .1em 0;display:inline-block}
  .emote.big{height:2.4em;margin:0 .1em}

  /* ---------- Stage ---------- */
  .stage{flex:1;position:relative;background:var(--key);overflow:hidden}
  .fsbtn{
    position:absolute;top:12px;right:12px;z-index:5;width:auto;flex:none;
    padding:8px 12px;font-size:12px;background:rgba(0,0,0,.55);border:1px solid rgba(255,255,255,.25);
    color:#fff;border-radius:7px;backdrop-filter:blur(2px);
  }
  .fsbtn:hover{background:rgba(0,0,0,.75)}
  .stage:fullscreen .fsbtn{opacity:.15}
  .stage:fullscreen .fsbtn:hover{opacity:1}

  .chat{
    position:absolute;left:0;right:0;
    padding:14px 16px;
    display:flex;flex-direction:column;justify-content:flex-end;gap:var(--gap);
    max-height:100%;overflow:hidden;
  }
  .chat.bottom{bottom:0;top:auto}
  .chat.top{top:0;bottom:auto;justify-content:flex-start}

  .msg{
    font-size:var(--font-size);
    line-height:1.35;
    word-wrap:break-word;
    animation:pop .18s ease-out;
    color:#fff;
  }
  @keyframes pop{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

  /* boxed style */
  .chat.boxed .msg{
    background:rgba(24,24,27,.92);
    padding:7px 11px;border-radius:9px;width:fit-content;max-width:100%;
  }
  .chat.boxed.top .msg{margin-left:0}

  .badges{display:inline-flex;gap:3px;vertical-align:middle;margin-right:4px;position:relative;top:-1px}
  .badge{width:1em;height:1em;border-radius:3px;display:inline-block;vertical-align:middle}
  .uname{font-weight:700}
  .colon{color:#fff;font-weight:400;opacity:.85}
  .body{font-weight:400}
  .ts{color:rgba(255,255,255,.55);font-size:.72em;margin-right:6px;font-weight:500;font-variant-numeric:tabular-nums}

  /* text legibility helper for non-boxed mode */
  .chat.shadow .msg{text-shadow:0 1px 2px rgba(0,0,0,.55)}
</style>
</head>
<body>
  <aside class="controls">
    <h1><span class="dot"></span> Twitch Chat → Green Screen</h1>

    <div class="grp">
      <label>Chat JSON (array of messages)</label>
      <textarea id="json" spellcheck="false"></textarea>
      <div class="err" id="err"></div>
    </div>

    <div class="row">
      <button class="primary" id="play">▶ Stream in</button>
      <button id="showall">Show all</button>
      <button id="clear">Clear</button>
    </div>

    <div class="grp">
      <label>Emotes (one image link per line)</label>
      <textarea id="emoteUrls" spellcheck="false" style="height:90px"></textarea>
      <button id="loadEmotes">Load emotes</button>
      <div class="thumbs" id="thumbs"></div>
      <div class="opt"><span>Sprinkle chance</span>
        <input type="range" id="emFreq" min="0" max="100" value="35">
        <span class="val" id="emFreqv">35%</span></div>
      <div class="opt"><span>Emote-only chance</span>
        <input type="range" id="emOnly" min="0" max="100" value="15">
        <span class="val" id="emOnlyv">15%</span></div>
      <p class="hint" style="margin-top:2px">Click a thumbnail to toggle it on/off. Active emotes get sprinkled into random messages; some messages become emote-only (name still shows). Works with Twitch / 7TV / BTTV emote image URLs.</p>
    </div>

    <div class="grp">
      <label>Style</label>
      <div class="seg" id="style">
        <button data-style="classic" class="on">Classic</button>
        <button data-style="boxed">Boxed</button>
      </div>
    </div>

    <div class="grp">
      <label>Anchor</label>
      <div class="seg" id="anchor">
        <button data-anchor="bottom" class="on">Bottom</button>
        <button data-anchor="top">Top</button>
      </div>
    </div>

    <div class="grp">
      <label>Key color</label>
      <div class="swatches" id="swatches">
        <div class="sw on" style="background:#00ff00" data-key="#00ff00" title="Green"></div>
        <div class="sw" style="background:#0000ff" data-key="#0000ff" title="Blue"></div>
        <div class="sw" style="background:#ff00ff" data-key="#ff00ff" title="Magenta"></div>
      </div>
    </div>

    <div class="grp">
      <label>Options</label>
      <div class="opt"><span>Font size</span>
        <input type="range" id="fs" min="12" max="40" value="18">
        <span class="val" id="fsv">18px</span></div>
      <div class="opt"><span>Line gap</span>
        <input type="range" id="gap" min="0" max="24" value="6">
        <span class="val" id="gapv">6px</span></div>
      <div class="opt"><span>Stream speed</span>
        <input type="range" id="spd" min="150" max="2500" value="900" step="50">
        <span class="val" id="spdv">0.9s</span></div>
      <label class="switch"><input type="checkbox" id="colon"> Show colon after name</label>
      <label class="switch"><input type="checkbox" id="ts"> Show timestamps</label>
      <label class="switch"><input type="checkbox" id="shadow"> Text shadow (classic)</label>
    </div>

    <p class="hint">Hit <b>Stream in</b> to make messages drip in like real chat, or <b>Show all</b> to dump them at once. Use the <b>Fullscreen</b> button on the green area, then window/display-capture it in OBS and apply a Chroma Key filter set to your chosen color.</p>
  </aside>

  <main class="stage" id="stage">
    <button class="fsbtn" id="fs-btn">⛶ Fullscreen</button>
    <div class="chat bottom classic" id="chat"></div>
  </main>

<script>
const SAMPLE = [
  {"id":1,"username":"pixelwitch","color":"#FF69B4","badge":"mod","message":"chat is popping off today"},
  {"id":2,"username":"GraniteGoose","color":"#1E90FF","badge":"vip","message":"that play was insane no cap"},
  {"id":3,"username":"lag_simulator","color":"#CD5C5C","badge":"sub","message":"finally someone says it"},
  {"id":4,"username":"thebigcheese","color":"#2E8B57","badge":"","message":"W stream"},
  {"id":5,"username":"NeonHusk","color":"#DAA520","badge":"prime","message":"been here since the start o7"},
  {"id":6,"username":"quietstorm","color":"#8A2BE2","badge":"broadcaster","message":"thanks for hanging out everyone"},
  {"id":7,"username":"frostbyte99","color":"#00CED1","badge":"sub","message":"PauseChamp"},
  {"id":8,"username":"mossy_log","color":"#9ACD32","badge":"","message":"how is the new patch feeling?"}
];

const DEFAULT_COLORS = ["#FF0000","#0000FF","#008000","#B22222","#FF7F50","#9ACD32","#FF4500","#2E8B57","#DAA520","#D2691E","#5F9EA0","#1E90FF","#FF69B4","#8A2BE2","#00FF7F"];

// classic global Twitch emote image URLs as a starting set (swap for your own)
const SAMPLE_EMOTES = [
  "https://static-cdn.jtvnw.net/emoticons/v2/25/default/dark/3.0",
  "https://static-cdn.jtvnw.net/emoticons/v2/354/default/dark/3.0",
  "https://static-cdn.jtvnw.net/emoticons/v2/86/default/dark/3.0",
  "https://static-cdn.jtvnw.net/emoticons/v2/41/default/dark/3.0",
  "https://static-cdn.jtvnw.net/emoticons/v2/33/default/dark/3.0",
  "https://static-cdn.jtvnw.net/emoticons/v2/245/default/dark/3.0"
];
let emotes = [];                            // {url, on}
let rollSeed = (Math.random()*1e9)>>>0;     // re-rolled on each Play / Show all

function mulberry32(a){return function(){a|=0;a=a+0x6D2B79F5|0;let t=Math.imul(a^a>>>15,1|a);t=t+Math.imul(t^t>>>7,61|t)^t;return ((t^t>>>14)>>>0)/4294967296;};}
function hashStr(s){s=String(s);let h=2166136261>>>0;for(let i=0;i<s.length;i++){h^=s.charCodeAt(i);h=Math.imul(h,16777619);}return h>>>0;}
function emoteImg(url,big){return `<img class="emote${big?' big':''}" src="${String(url).replace(/"/g,'%22')}" alt="" onerror="this.remove()">`;}

// Badge icons (simple recognizable approximations of Twitch badges)
function badgeSVG(name){
  const n = (name||"").toLowerCase().trim();
  const map = {
    broadcaster:`<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" rx="4" fill="#e91916"/><circle cx="10" cy="10" r="4" fill="#fff"/></svg>`,
    mod:`<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" rx="4" fill="#00ad03"/><path d="M6 13l5-5 1 1-5 5zM12 5l3 3-1.5 1.5-3-3z" fill="#fff"/></svg>`,
    vip:`<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" rx="4" fill="#e005b9"/><path d="M10 4l4 5-4 7-4-7z" fill="#fff"/></svg>`,
    sub:`<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" rx="4" fill="#9147ff"/><path d="M10 4l1.6 3.4 3.7.4-2.8 2.5.8 3.6L10 12.6 6.7 14.4l.8-3.6L4.7 8.3l3.7-.5z" fill="#fff"/></svg>`,
    subscriber:`__sub__`,
    prime:`<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" rx="4" fill="#00a4ff"/><path d="M4 7l3 2 3-4 3 4 3-2v6H4z" fill="#fff"/></svg>`,
    turbo:`<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" rx="4" fill="#6441a4"/><path d="M11 4l-5 7h3l-1 5 5-7h-3z" fill="#fff"/></svg>`,
    verified:`<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" rx="4" fill="#9147ff"/><path d="M5 10l3 3 6-6-1.3-1.3L8 10.3 6.3 8.7z" fill="#fff"/></svg>`,
    partner:`__verified__`,
    founder:`<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" rx="4" fill="#d4a017"/><path d="M10 4l1.6 3.4 3.7.4-2.8 2.5.8 3.6L10 12.6 6.7 14.4l.8-3.6L4.7 8.3l3.7-.5z" fill="#fff"/></svg>`,
    staff:`<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" rx="4" fill="#4b367c"/><circle cx="10" cy="8" r="3" fill="#fff"/><path d="M5 16c0-3 10-3 10 0z" fill="#fff"/></svg>`,
  };
  let v = map[n];
  if(!v) return null;
  if(v === "__sub__") v = map.sub;
  if(v === "__verified__") v = map.verified;
  return v;
}

const el = id => document.getElementById(id);
const chat = el('chat');
const stage = el('stage');
let messages = [];
let streamTimer = null;

function parseJSON(){
  el('err').textContent = "";
  let raw = el('json').value.trim();
  if(!raw){ el('err').textContent = "Paste some JSON first."; return null; }
  try{
    let data = JSON.parse(raw);
    if(!Array.isArray(data)) data = [data];
    return data;
  }catch(e){
    el('err').textContent = "Invalid JSON: " + e.message;
    return null;
  }
}

function colorFor(m){
  if(m.color && /^#?[0-9a-f]{3,8}$/i.test(m.color)) return m.color.startsWith('#')?m.color:('#'+m.color);
  // deterministic fallback from username
  let h=0; const u=(m.username||"anon");
  for(let i=0;i<u.length;i++) h=(h*31+u.charCodeAt(i))>>>0;
  return DEFAULT_COLORS[h % DEFAULT_COLORS.length];
}

function esc(s){ const d=document.createElement('div'); d.textContent = s==null?"":String(s); return d.innerHTML; }

function nowStamp(){
  const d=new Date();
  return d.getHours().toString().padStart(2,'0')+":"+d.getMinutes().toString().padStart(2,'0');
}

function buildMsg(m){
  const div = document.createElement('div');
  div.className = 'msg';
  let html = "";
  if(el('ts').checked) html += `<span class="ts">${nowStamp()}</span>`;
  const svg = badgeSVG(m.badge);
  if(svg) html += `<span class="badges"><span class="badge">${svg}</span></span>`;
  html += `<span class="uname" style="color:${colorFor(m)}">${esc(m.username)}</span>`;
  html += el('colon').checked ? `<span class="colon">:</span> ` : ` `;

  const act = emotes.filter(e=>e.on);
  let body;
  if(act.length){
    const rng = mulberry32(hashStr(rollSeed + ':' + (m.id ?? m.username ?? '') + ':' + (m.message ?? '')));
    const onlyChance = (+el('emOnly').value)/100;
    const sprinkleChance = (+el('emFreq').value)/100;
    const pick = ()=> act[Math.floor(rng()*act.length)].url;
    if(rng() < onlyChance){
      const n = 1 + Math.floor(rng()*3);          // 1-3 emotes, no text
      let s=""; for(let i=0;i<n;i++) s += emoteImg(pick(), true);
      body = s;
    } else {
      body = esc(m.message);
      if(rng() < sprinkleChance){
        const n = 1 + Math.floor(rng()*2);        // tack 1-2 emotes onto the text
        for(let i=0;i<n;i++) body += " " + emoteImg(pick(), false);
      }
    }
  } else {
    body = esc(m.message);
  }
  html += `<span class="body">${body}</span>`;
  div.innerHTML = html;
  return div;
}

function append(m){
  const node = buildMsg(m);
  if(chat.classList.contains('top')) chat.appendChild(node);
  else chat.appendChild(node);
  // trim if overflowing to keep it clean
  while(chat.scrollHeight > stage.clientHeight && chat.children.length>1){
    chat.removeChild(chat.firstChild);
  }
}

function showAll(){
  stopStream();
  chat.innerHTML = "";
  const data = parseJSON(); if(!data) return;
  messages = data;
  data.forEach(append);
}

function streamIn(){
  stopStream();
  chat.innerHTML = "";
  const data = parseJSON(); if(!data) return;
  messages = data;
  let i = 0;
  const speed = +el('spd').value;
  const tick = ()=>{
    if(i>=messages.length){ stopStream(); return; }
    append(messages[i]); i++;
    // tiny natural jitter so it doesn't feel robotic
    const jitter = speed*(0.7+Math.random()*0.6);
    streamTimer = setTimeout(tick, jitter);
  };
  tick();
  el('play').textContent = "■ Stop";
}

function stopStream(){
  if(streamTimer){ clearTimeout(streamTimer); streamTimer=null; }
  el('play').textContent = "▶ Stream in";
}

// ---- wiring ----
el('json').value = JSON.stringify(SAMPLE, null, 2);
el('emoteUrls').value = SAMPLE_EMOTES.join("\n");

function rerender(){ if(!streamTimer && chat.children.length) showAll(); }

function renderThumbs(){
  const c = el('thumbs'); c.innerHTML = "";
  emotes.forEach((e)=>{
    const t = document.createElement('div');
    t.className = 'thumb' + (e.on?' on':'');
    t.innerHTML = `<img src="${String(e.url).replace(/"/g,'%22')}" alt="" onerror="this.parentElement.style.opacity=.12">`;
    t.onclick = ()=>{ e.on = !e.on; t.classList.toggle('on', e.on); rerender(); };
    c.appendChild(t);
  });
}
function loadEmotes(){
  const urls = el('emoteUrls').value.split(/\s+/).map(s=>s.trim()).filter(Boolean);
  emotes = urls.map(u=>({url:u, on:true}));
  renderThumbs();
  rerender();
}
el('loadEmotes').onclick = loadEmotes;
el('emFreq').oninput = e=> el('emFreqv').textContent = e.target.value+'%';
el('emOnly').oninput = e=> el('emOnlyv').textContent = e.target.value+'%';
el('emFreq').onchange = el('emOnly').onchange = rerender;

function reseed(){ rollSeed = (Math.random()*1e9)>>>0; }
el('play').onclick = ()=>{ if(streamTimer){ stopStream(); } else { reseed(); streamIn(); } };
el('showall').onclick = ()=>{ reseed(); showAll(); };
el('clear').onclick = ()=>{ stopStream(); chat.innerHTML=""; };

el('fs').oninput = e=>{ document.documentElement.style.setProperty('--font-size', e.target.value+'px'); el('fsv').textContent=e.target.value+'px'; };
el('gap').oninput = e=>{ document.documentElement.style.setProperty('--gap', e.target.value+'px'); el('gapv').textContent=e.target.value+'px'; };
el('spd').oninput = e=>{ el('spdv').textContent=(e.target.value/1000).toFixed(2).replace(/0$/,'')+'s'; };

el('colon').onchange = el('ts').onchange = ()=>{ if(chat.children.length) (streamTimer?null:showAll()); };
el('shadow').onchange = e=> chat.classList.toggle('shadow', e.target.checked);

document.querySelectorAll('#style button').forEach(b=> b.onclick=()=>{
  document.querySelectorAll('#style button').forEach(x=>x.classList.remove('on'));
  b.classList.add('on');
  chat.classList.toggle('boxed', b.dataset.style==='boxed');
  chat.classList.toggle('classic', b.dataset.style==='classic');
});
document.querySelectorAll('#anchor button').forEach(b=> b.onclick=()=>{
  document.querySelectorAll('#anchor button').forEach(x=>x.classList.remove('on'));
  b.classList.add('on');
  chat.classList.toggle('bottom', b.dataset.anchor==='bottom');
  chat.classList.toggle('top', b.dataset.anchor==='top');
});
document.querySelectorAll('#swatches .sw').forEach(s=> s.onclick=()=>{
  document.querySelectorAll('#swatches .sw').forEach(x=>x.classList.remove('on'));
  s.classList.add('on');
  document.documentElement.style.setProperty('--key', s.dataset.key);
});

el('fs-btn').onclick = ()=>{
  if(!document.fullscreenElement) stage.requestFullscreen?.();
  else document.exitFullscreen?.();
};

// first paint
loadEmotes();
showAll();
</script>
</body>
</html>
